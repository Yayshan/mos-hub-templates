# Storage locations
DATA_LOCATION=./data
DB_DATA_LOCATION=./postgres
WEBSERVER_CONFIG_LOCATION=./config/nginx.conf

# Auto-created admin account
POSTGRES_HOST=nextcloud-database
REDIS_HOST=nextcloud-redis

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
