{
  "name": "Vaultwarden",
  "repo": "docker.io/vaultwarden/server:alpine",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped --no-healthcheck",
  "web_ui_url": "http://[IP]:[PORT:8000]",
  "icon": "https://raw.githubusercontent.com/Yayshan/MOS-HUB-Templates/refs/heads/main/images/vaultwarden.png",
  "project": "https://github.com/dani-garcia/vaultwarden",
  "support": "https://github.com/dani-garcia/vaultwarden/issues",
  "description": "An alternative server implementation of the Bitwarden Client API, written in Rust and compatible with official Bitwarden clients [disclaimer], perfect for self-hosted deployment where running the official resource-heavy service might not be ideal.",
  "paths": [
    {
      "name": "Vaultwarden Data",
      "mode": "",
      "host": "/mnt/cache/appdata/vaultwarden",
      "container": "/data"
    },
    {
      "name": "MOS X509 Server Certificate",
      "mode": "ro",
      "host": "/etc/nginx/ssl",
      "container": "/ssl"
    }
  ],
  "ports": [
    {
      "name": "",
      "protocol": "",
      "host": "8000",
      "container": "80"
    }
  ],
  "variables": [
    {
      "name": "",
      "key": "ROCKET_TLS",
      "value": "{certs="/ssl/nginx.crt",key="/ssl/nginx.key"}",
      "description": "Use the x509 direct from the mos server without setting up an reverse proxy",
      "required": true,
      "mask": true
    }
  ],
  "devices": []
}